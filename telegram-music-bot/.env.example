# ── Your Telegram Account ─────────────────────────────────────────────────────
# Get from https://my.telegram.org/apps
API_ID=
API_HASH=

# String session for YOUR account — run: python generate_session.py
STRING_SESSION=

# ── Spotify ───────────────────────────────────────────────────────────────────
# Create a free app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Local:  mongodb://localhost:27017
# Atlas:  mongodb+srv://user:pass@cluster.mongodb.net/
MONGO_URI=mongodb://localhost:27017
DB_NAME=music_bot

# ── Bot Settings ──────────────────────────────────────────────────────────────
# Command prefix your account responds to (default: /)
CMD_PREFIX=/

# Default volume 0-200
DEFAULT_VOLUME=100

# Audio quality in kbps (128 / 192 / 320)
AUDIO_QUALITY=192

# Your own Telegram user ID — gives you admin control in every group
# Find your ID by messaging @userinfobot on Telegram
ADMIN_IDS=

# Log level: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

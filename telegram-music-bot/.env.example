# ── Telegram ──────────────────────────────────────────────────────────────────
# Get from https://my.telegram.org/apps
API_ID=
API_HASH=

# Bot token from @BotFather
BOT_TOKEN=

# Userbot string session (see README for how to generate)
STRING_SESSION=

# ── Spotify ───────────────────────────────────────────────────────────────────
# Create an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Local:   mongodb://localhost:27017
# Atlas:   mongodb+srv://user:pass@cluster.mongodb.net/
MONGO_URI=mongodb://localhost:27017
DB_NAME=music_bot

# ── Bot settings ──────────────────────────────────────────────────────────────
# Default volume (0-200)
DEFAULT_VOLUME=100

# Audio quality in kbps (128 / 192 / 320)
AUDIO_QUALITY=192

# Comma-separated Telegram user IDs who are global admins (optional)
ADMIN_IDS=

# Log level: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
